      "}"
    ],
    "description": "Else-if block"
  },
  "switch": {
    "prefix": "switch",
    "body": [
      "switch ($1) {",
      "\tcase $2:",
      "\t\t$3",
      "\t\tbreak;",
      "\tdefault:",
      "\t\t$4",
      "}"
    ],
    "description": "Switch statement"
  },
  "return": {
    "prefix": "return",
    "body": [
