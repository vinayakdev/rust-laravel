  },
  "try/catch": {
    "prefix": "try",
    "body": [
      "try {",
      "\t$1",
      "} catch (${2:Exception} \\$e) {",
      "\t$3",
      "}"
    ],
    "description": "Try-catch block"
  },
  "try/catch/finally": {
    "prefix": "tryf",
    "body": [
      "try {",
      "\t$1",
      "} catch (${2:Exception} \\$e) {",
      "\t$3",
      "} finally {",
      "\t$4",
      "}"
