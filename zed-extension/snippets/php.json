      "}"
    ],
    "description": "Foreach loop"
  },
  "for": {
    "prefix": "for",
    "body": [
      "for ($1 = 0; $1 < $2; $1++) {",
      "\t$3",
      "}"
    ],
    "description": "For loop"
  },
  "while": {
    "prefix": "while",
    "body": [
      "while ($1) {",
      "\t$2",
      "}"
    ],
    "description": "While loop"
  },
  "if/else": {
    "prefix": "ifelse",
    "body": [
      "if ($1) {",
      "\t$2",
      "} else {",
      "\t$3",
      "}"
    ],
    "description": "If-else statement"
  },
  "if": {
    "prefix": "if",
    "body": [
      "if ($1) {",
      "\t$2",
      "}"
    ],
    "description": "If statement"
  },
  "else": {
