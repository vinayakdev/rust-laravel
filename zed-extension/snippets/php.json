    ],
    "description": "Class property with visibility"
  },
  "Livewire component": {
    "prefix": "livewire:component",
    "body": [
      "use Livewire\\Component;",
      "",
      "class ${1:ComponentName} extends Component",
      "{",
      "\tpublic ${2:string} \\$$3 = ${4:''};",
      "",
      "\tpublic function ${5:save}(): void",
      "\t{",
      "\t\t$6",
      "\t}",
      "",
      "\tpublic function render()",
      "\t{",
      "\t\treturn view('${7:livewire.component-name}');",
      "\t}",
      "}"
    ],
    "description": "Livewire component class with render method"
  },
  "Livewire view layout": {
    "prefix": "livewire:view",
    "body": [
      "return view('${1:livewire.component-name}')->layout('${2:components.layouts.app}');"
    ],
    "description": "Return a Livewire view with chained layout"
  },
  "Livewire::component": {
    "prefix": "Livewire::component",
    "body": [
      "Livewire::component('${1:component-name}', ${2:ComponentName}::class);"
    ],
    "description": "Register a Livewire component alias"
  },
  "__construct": {
    "prefix": "construct",
    "body": [
      "public function __construct($1) {",
      "\t$2",
      "}"
    ],
    "description": "Constructor method"
  },
  "array": {
    "prefix": "arr",
    "body": [
      "[$1]"
    ],
    "description": "Array declaration"
  },
  "anonymous function": {
    "prefix": "afunc",
    "body": [
      "function($1) {",
      "\t$2",
      "}"
    ],
    "description": "Anonymous/lambda function"
  }
