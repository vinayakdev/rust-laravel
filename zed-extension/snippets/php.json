      "\t$1",
      "} catch (${2:Exception} \\$e) {",
      "\t$3",
      "} finally {",
      "\t$4",
      "}"
    ],
    "description": "Try-catch-finally block"
  },
  "foreach": {
    "prefix": "foreach",
    "body": [
      "foreach ($1 as $2) {",
