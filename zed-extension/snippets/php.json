{
  "class": {
    "prefix": "class",
    "body": [
      "class $1 ${2:extends $3} ${4:implements $5} {",
      "\t$6",
      "}"
    ],
    "description": "PHP class definition"
  },
  "public function": {
    "prefix": "pub",
    "body": [
      "public function $1($2)${3:: $4} {",
      "\t$5",
      "}"
    ],
    "description": "Public function"
  },
  "private function": {
    "prefix": "priv",
    "body": [
      "private function $1($2)${3:: $4} {",
      "\t$5",
      "}"
    ],
    "description": "Private function"
  },
  "protected function": {
    "prefix": "prot",
    "body": [
      "protected function $1($2)${3:: $4} {",
      "\t$5",
      "}"
    ],
    "description": "Protected function"
  },

  "pubf": {
    "prefix": "pubf",
    "body": [
      "public function ${1:name}(${2}): ${3:void}",
      "{",
      "\t$0",
      "}"
    ],
    "description": "Public function (unambiguous)"
  },
  "prof": {
    "prefix": "prof",
    "body": [
      "protected function ${1:name}(${2}): ${3:void}",
      "{",
      "\t$0",
      "}"
    ],
    "description": "Protected function"
  },
  "prif": {
    "prefix": "prif",
    "body": [
      "private function ${1:name}(${2}): ${3:void}",
